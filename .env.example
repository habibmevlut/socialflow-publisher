# Auth (NextAuth.js - web ve API icin ayni secret)
AUTH_SECRET=  # olusturmak icin: npx auth secret
NEXTAUTH_URL=http://localhost:3001  # Production: https://yourdomain.com

# API (backend)
API_PORT=4000
# Railway / Render vb. genelde PORT verir; bos birakilabilir (API_PORT ile ezilir)
# PORT=

# Web -> API baglantisi (Next.js public env)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Redis (BullMQ — API + worker)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Railway / Upstash: tek satir (varsa REDIS_HOST/PORT yerine bu yeter)
# REDIS_URL=redis://default:PAROLA@HOST:6379

# YouTube OAuth (Google Cloud Console'dan al)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Instagram OAuth (Meta for Developers'dan al - Instagram Business Login)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Facebook OAuth (Meta - Instagram ile ayni uygulama kullanilabilir)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_BASE=
# Meta localhost kabul etmiyor - ngrok URL gerekli (pnpm tunnel)
# Local: https://xxxx.ngrok-free.app | Production: https://api.yourdomain.com
INSTAGRAM_REDIRECT_BASE=

# TikTok OAuth (TikTok for Developers - Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Callback adresi: asagidaki deger + "/auth/tiktok/callback" Portal'daki Redirect URI ile BIREBIR ayni olmali.
# Sandbox: "localhost" kelimesi Portal'da cok sik reddedilir; 127.0.0.1 kullan.
# Ornek (lokal API 4000): http://127.0.0.1:4000  -> Portal URI: http://127.0.0.1:4000/auth/tiktok/callback
# Tunnel / production API: https://api-domainin  -> Portal: https://api-domainin/auth/tiktok/callback
# Bos birakilirsa kod varsayilan http://localhost:4000 kullanir (TikTok Sandbox ile uyusmeyebilir).
TIKTOK_REDIRECT_BASE=http://127.0.0.1:4000

API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/socialflow?schema=public"

# MinIO (S3-uyumlu object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=socialflow-videos
# Instagram videoyu URL'den indirir - localhost erisilemez. MinIO'yu ngrok ile ac: ngrok http 9000
MINIO_PUBLIC_BASE_URL=
