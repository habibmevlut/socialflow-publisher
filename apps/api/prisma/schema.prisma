generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// seed ile test org olusturmak icin: pnpm exec prisma db seed

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      String?  @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialAccounts SocialAccount[]
  posts          Post[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdPosts Post[] @relation("CreatedBy")
}

model SocialAccount {
  id                 String   @id @default(cuid())
  organizationId     String
  platform           String   // instagram | youtube | tiktok | facebook
  externalAccountId  String?
  displayName        String?
  status             String   @default("active") // active | expired | revoked
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  postTargets  PostTarget[]
  token        SocialToken?
}

model SocialToken {
  id                String   @id @default(cuid())
  socialAccountId   String   @unique
  accessToken       String   // MVP: plain; production'da sifreli
  refreshToken      String?
  expiresAt         DateTime?
  scopes            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
}

model Post {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  videoUrl       String
  status         String    @default("draft") // draft | pending_approval | approved | scheduled | published | failed
  scheduledAt    DateTime? // zamanlanmis paylasim tarihi
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  targets      PostTarget[]
}

model PostTarget {
  id              String    @id @default(cuid())
  postId          String
  socialAccountId String?
  platform        String    // instagram | youtube | tiktok | facebook
  accountId       String    // API'den gelen accountId (social_accounts.id veya harici id)
  caption         String?
  enabled         Boolean   @default(true)
  status          String    @default("pending") // pending | published | failed
  errorMessage    String?  // yukleme hatasi mesaji (kullaniciya gosterilir)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
}
