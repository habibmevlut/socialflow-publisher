{
  "name": "socialflow-publisher",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "docker compose up -d postgres redis minio && turbo run dev --parallel",
    "tunnel": "ngrok http 4000",
    "tunnel:cf": "cloudflared tunnel --url http://localhost:4000",
    "tunnel:cf:minio": "cloudflared tunnel --url http://localhost:9000",
    "db:studio": "node scripts/db-studio.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "ngrok": "^5.0.0-beta.2",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  }
}
